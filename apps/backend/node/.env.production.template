# CalCalCal Production Environment Variables
# Copy this file to .env.production and fill in the actual values
# DO NOT commit .env.production to git!

# --- Server Configuration ---
NODE_ENV=production
PORT=3000

# --- JWT Authentication ---
# IMPORTANT: Copy this from your Digital Ocean environment
JWT_SECRET=COPY_FROM_DIGITAL_OCEAN

# --- AI Provider Configuration ---
# Choose your AI provider: "openai" or "gemini"
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=COPY_FROM_DIGITAL_OCEAN
AI_OPENAI_MODEL=gpt-4o-mini

# Gemini Configuration (if using Gemini instead)
GEMINI_API_KEY=COPY_FROM_DIGITAL_OCEAN_IF_USING_GEMINI
AI_GEMINI_MODEL=gemini-2.5-flash

# AI Settings
AI_TEMPERATURE=0.2
AI_PROMPT_VERSION=v1
AI_MAX_CONCURRENCY=3
AI_PROVIDER_TIMEOUT_MS=45000

# --- Cloudflare R2 Storage ---
# IMPORTANT: Copy these from your Digital Ocean environment
R2_ACCOUNT_ID=COPY_FROM_DIGITAL_OCEAN
R2_ACCESS_KEY_ID=COPY_FROM_DIGITAL_OCEAN
R2_SECRET_ACCESS_KEY=COPY_FROM_DIGITAL_OCEAN
R2_BUCKET=COPY_FROM_DIGITAL_OCEAN
R2_PUBLIC_BASE_URL=COPY_FROM_DIGITAL_OCEAN

# --- Optional Configuration ---
# Public base URL for building absolute URLs
PUBLIC_BASE_URL=https://api.calcalcal.app

# Database pool size (default: 5, increase for more concurrent requests)
DB_POOL_MAX=5

# --- Notes ---
# The DATABASE_URL is already configured in docker-compose.production.yml
# It points to the PostgreSQL container: postgresql://calcalcal:NeonGenezisEva02!@postgres:5432/calcalcal_production

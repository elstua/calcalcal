# CalCalCal Node Backend - Environment Example

# --- Server ---
PORT=3000
JWT_SECRET=change-me-in-dev-and-prod

# --- Apple Sign-In ---
# Optional: set expected audience/client_id if you want strict aud checking
# APPLE_AUDIENCE=com.your.bundle.id

# --- Database ---
# Local PostgreSQL or remote DB URL
# Example local (default Postgres):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/calcalcal_dev
DATABASE_URL=

# --- AI / OpenAI ---
OPENAI_API_KEY=

# --- AI / Gemini ---
GEMINI_API_KEY=

# --- AI Provider Config ---
# Provider selection (future: 'openai', 'anthropic', 'azureopenai', etc)
# Providers: openai (default) or gemini
AI_PROVIDER=openai
# Default model and settings
AI_OPENAI_MODEL=gpt-4o-mini
AI_GEMINI_MODEL=gemini-2.5-flash
AI_TEMPERATURE=0.2
AI_PROMPT_VERSION=v1

# --- Optional Integrations ---
REDIS_URL=
# Public base URL for building absolute URLs (optional).
# Example: https://your-vps-domain.com
PUBLIC_BASE_URL=

# --- Cloudflare R2 (production image storage) ---
# S3-compatible credentials
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for your bucket (R2 Custom Domain, e.g. https://media.yourdomain.com)
R2_PUBLIC_BASE_URL=

# Notes:
# - For local dev, copy to .env.local:  cp ENV.example .env.local
# - The app loads .env.local automatically via dotenv


# CalCalCal Node Backend - Environment Example

# --- Server ---
PORT=3000
JWT_SECRET=change-me-in-dev-and-prod

# --- Apple Sign-In ---
# Optional: set expected audience/client_id if you want strict aud checking
# APPLE_AUDIENCE=com.your.bundle.id

# --- Database ---
# Use Supabase local Postgres (default CLI credentials) or your remote DB URL
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Supabase ---
# Copy these from your Supabase project or local CLI
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=

# --- AI / OpenAI ---
OPENAI_API_KEY=

# --- AI Provider Config ---
# Provider selection (future: 'openai', 'anthropic', 'azureopenai', etc)
AI_PROVIDER=openai
# Default model and settings
AI_OPENAI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.2
AI_PROMPT_VERSION=v1

# --- Optional Integrations ---
REDIS_URL=
S3_HOST=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# SMS Provider (if used by Supabase Auth SMS)
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=

# Notes:
# - For local dev, copy to .env.local:  cp ENV.example .env.local
# - The app loads .env.local automatically via dotenv

